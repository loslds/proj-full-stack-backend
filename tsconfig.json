{
  "compilerOptions": {
    "target": "ES2020", // Código de saída moderno, compatível com Node 14+
    "module": "commonjs", // Compatível com require/import no Node
    "rootDir": "src", // Onde ficam os arquivos de entrada
    "outDir": "dist", // Onde será gerado o JS compilado
    "strict": true, // Habilita checagens mais rigorosas do TypeScript
    "esModuleInterop": true, // Permite import padrão de libs CommonJS
    "skipLibCheck": true, // Ignora verificação de tipos de libs (mais rápido)
    "forceConsistentCasingInFileNames": true, // Evita problemas de maiúsculas/minúsculas em imports
    "resolveJsonModule": true, // Permite importar arquivos .json
    "moduleResolution": "node", // Resolve imports no estilo Node.js
    "sourceMap": true, // Gera mapas de código (debug no TS)
    "noImplicitAny": false, // Permite variáveis sem tipo explícito

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
