{
  "name": "proj-full-stack-backend",
  "version": "1.0.0",
  "description": "Backend do projeto JrBordados Full Stack",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "ts:build": "tsc",
    "copy-assets": "cpx \"src/assets/**\" dist/assets",
    "build": "yarn ts:build && yarn copy-assets",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "ts:clean": "tsc --build --clean",
    "ts:check": "tsc --noEmit"
  },
  "author": "Seu Nome",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.12.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.5.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.17",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/node": "^24.4.0",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.35.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.3"
  }
}
